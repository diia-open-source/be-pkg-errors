{
    "name": "@diia-inhouse/errors",
    "version": "2.2.1",
    "type": "module",
    "description": "Custom errors",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "author": "Diia",
    "repository": "https://github.com/diia-open-source/be-pkg-errors",
    "license": "SEE LICENSE IN LICENSE.md",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "prepare": "npm run build",
        "build": "tsdown",
        "semantic-release": "semantic-release",
        "start": "npm run build && node dist/index.js",
        "lint": "oxlint && oxfmt --check .",
        "lint-fix": "oxlint --fix && oxfmt .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "peerDependencies": {
        "@diia-inhouse/types": ">=13.1.0"
    },
    "dependencies": {
        "@diia-inhouse/types": "14.1.0"
    },
    "devDependencies": {
        "@diia-inhouse/configs": "7.0.1",
        "@diia-inhouse/oxc-config": "1.11.0",
        "@diia-inhouse/test": "8.2.16",
        "@vitest/coverage-v8": "4.1.5",
        "@vitest/ui": "4.1.5",
        "lockfile-lint": "5.0.0",
        "madge": "8.0.0",
        "oxfmt": "0.48.0",
        "oxlint": "1.63.0",
        "oxlint-tsgolint": "0.22.1",
        "rimraf": "6.1.3",
        "semantic-release": "25.0.3",
        "tsdown": "0.22.0",
        "typescript": "5.9.3",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.1.5",
        "vitest-mock-extended": "4.0.0"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package",
        "branches": [
            "main"
        ]
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
