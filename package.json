{
    "name": "@diia-inhouse/errors",
    "version": "1.18.8",
    "description": "Custom errors",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "author": "Diia",
    "repository": "https://github.com/diia-open-source/be-pkg-errors.git",
    "license": "SEE LICENSE IN LICENSE.md",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "prepare": "npm run build",
        "build": "tsc",
        "semantic-release": "semantic-release",
        "start": "npm run build && node dist/index.js",
        "lint": "eslint . && prettier --check .",
        "lint-fix": "eslint --fix . && prettier --write .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "peerDependencies": {
        "@diia-inhouse/types": ">=2.17.0"
    },
    "dependencies": {
        "@diia-inhouse/types": "11.6.0"
    },
    "devDependencies": {
        "@diia-inhouse/configs": "6.1.1",
        "@diia-inhouse/eslint-config": "8.8.0",
        "@diia-inhouse/test": "7.3.7",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/ui": "4.0.18",
        "eslint": "9.29.0",
        "lockfile-lint": "4.14.1",
        "madge": "8.0.0",
        "prettier": "3.8.1",
        "rimraf": "6.1.3",
        "semantic-release": "24.2.2",
        "ts-node": "10.9.2",
        "ts-patch": "3.3.0",
        "typescript": "5.9.3",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.0.18",
        "vitest-mock-extended": "3.1.0"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package",
        "branches": [
            "main"
        ]
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
